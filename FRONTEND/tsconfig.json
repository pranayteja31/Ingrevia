{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@expo/vector-icons": ["./node_modules/@expo/vector-icons/build/Icons.d.ts"],
      "@expo/vector-icons/*": ["./node_modules/@expo/vector-icons/build/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "declarations.d.ts"
  ]
}
